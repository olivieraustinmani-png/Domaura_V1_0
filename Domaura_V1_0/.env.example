# ============================================
# DOMAURA Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# APPLICATION
NODE_ENV=development
APP_NAME=DOMAURA
APP_VERSION=1.0.0
APP_PORT=3000
APP_HOST=localhost

# DATABASE - PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=domaura_user
DB_PASSWORD=change_me_in_production
DB_NAME=domaura_dev
DB_DIALECT=postgres
DB_LOGGING=false

# REDIS
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=0

# JWT & Authentication
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRATION=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRATION=30d

# FIREBASE
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_firebase_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_firebase_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# CLOUDINARY
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# PAYMENT PROVIDERS
ORANGE_MONEY_API_KEY=your_orange_money_key
ORANGE_MONEY_API_SECRET=your_orange_money_secret
MTN_MOMO_API_KEY=your_mtn_momo_key
MTN_MOMO_API_SECRET=your_mtn_momo_secret
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# EMAIL & NOTIFICATIONS
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@domaura.com
SENDGRID_API_KEY=your_sendgrid_api_key

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=domaura-bucket
AWS_CLOUDFRONT_DOMAIN=your_cloudfront_domain.cloudfront.net

# MONITORING & LOGGING
SENTRY_DSN=your_sentry_dsn
LOG_LEVEL=info
ELASTICSEARCH_HOST=localhost:9200

# EXTERNAL SERVICES
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token

# FEATURE FLAGS
FEATURE_3D_TOURS=false
FEATURE_VR_VISITS=false
FEATURE_AI_RECOMMENDATIONS=true
FEATURE_ESCROW=true
FEATURE_DOMAURA_PRO=false

# CORS & SECURITY
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# BACKEND URLs (for mobile/web communication)
API_URL=http://localhost:3000/api
WEBSOCKET_URL=ws://localhost:3000/socket

# FRONTEND URLs (for email links, redirects)
WEB_URL=http://localhost:3000
MOBILE_DEEP_LINK=domaura://

# ADMIN
ADMIN_EMAIL=admin@domaura.com
ADMIN_PASSWORD=change_me_in_production

# DOCKER COMPOSE
COMPOSE_PROJECT_NAME=domaura
POSTGRES_VERSION=15-alpine
REDIS_VERSION=7-alpine
NODE_VERSION=18-alpine

# DEVELOPMENT TOOLS
DEBUG=domaura:*
PRETTY_LOGS=true
